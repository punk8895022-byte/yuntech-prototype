                        <button onClick={() => updateMatQty(i, 1)} className="w-7 h-7 rounded-full bg-indigo-100 text-indigo-600">+</button>
                        <span className="font-mono font-bold text-indigo-600 w-20 text-right">${(m.price * m.qty).toLocaleString()}</span>
                      </div>
                    </div>
                  ))}

                  {materials.length === 0 && <div className="text-sm text-slate-400">尚未新增耗材，點「常用庫」可快速加入。</div>}

