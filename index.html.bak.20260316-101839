const pseudoDistanceKm = (seed) => {
  const s = String(seed || "");
  let h = 2166136261;
  for (let i = 0; i < s.length; i++) {
    h ^= s.charCodeAt(i);
    h = Math.imul(h, 16777619);
  }
  const km = (Math.abs(h) % 140 + 10) / 10; // 1.0 ~ 15.0
  return km;
};

