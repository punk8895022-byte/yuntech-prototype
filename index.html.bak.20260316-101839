                </div>
              </div>

              <div className="bg-white p-4 rounded-xl border border-slate-200">
                <div className="flex items-center justify-between mb-3">
                  <h4 className="font-bold text-slate-700 flex items-center gap-2"><Icon name="camera" /> 完工照片 (必填)</h4>
                  <span className={`text-xs font-bold ${photos.length > 0 ? "text-emerald-600" : "text-rose-600"}`}>{photos.length > 0 ? `已上傳 ${photos.length} 張` : "尚未上傳"}</span>
                </div>
                <div className="flex gap-2 overflow-x-auto pb-2">
                  <label className="w-20 h-20 border-2 border-dashed rounded-xl flex items-center justify-center text-slate-400 shrink-0 cursor-pointer hover:bg-slate-50">
                    <Icon name="plus" />
                    <input type="file" className="hidden" accept="image/*" multiple onChange={handlePhoto} />
                  </label>
                  {photos.map((p, i) => (
                    <div key={i} className="relative w-20 h-20 shrink-0">
                      <button onClick={() => openPhotoViewer(photos, i, photoMeta)} className="w-20 h-20 rounded-xl overflow-hidden border">
                        <img src={p} className="w-20 h-20 object-cover" />
                      </button>
                      <button onClick={() => removePhoto(i)} className="absolute -top-2 -right-2 w-6 h-6 rounded-full bg-slate-900/80 text-white flex items-center justify-center">×</button>
                    </div>
                  ))}
                </div>
                {photos.length > 0 && (
                  <div className="mt-3 space-y-2">
                    {photos.map((_, i) => (
                      <div key={`meta-${i}`} className="grid grid-cols-2 gap-2">
                        <input
                          className="input-modern py-2"
                          placeholder={`照片 ${i + 1} 說明`}
                          value={photoMeta[i]?.note || ""}
                          onChange={(e) => updatePhotoMeta(i, { note: e.target.value })}
                        />
                        <input
                          className="input-modern py-2"
                          placeholder={`照片 ${i + 1} 點位/位置`}
                          value={photoMeta[i]?.mark || ""}
                          onChange={(e) => updatePhotoMeta(i, { mark: e.target.value })}
                        />
                      </div>
                    ))}
                  </div>
                )}
              </div>

              <SignaturePad value={signature} onChange={setSignature} />

              <button
                onClick={submit}
                disabled={!canSubmit}
                className={`w-full btn btn-primary py-4 text-lg shadow-xl shadow-indigo-200 ${!canSubmit ? "opacity-50 pointer-events-none" : ""}`}
              >
                送出報告
              </button>
            </div>
          )}
        </div>

        <div className="p-6 border-t bg-white sticky bottom-0">
          {job.status === "open" && isEng && <button onClick={() => handleAction("take")} className="w-full btn btn-primary shadow-xl shadow-indigo-200">立即接案</button>}
          {job.status === "completed" && !isEng && <button onClick={() => handleAction("pay")} className="w-full btn btn-primary bg-green-600 shadow-xl shadow-green-200">驗收付款</button>}
        </div>
      </div>
    </div>
  );
};

