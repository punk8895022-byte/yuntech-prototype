};
const DiagnosticsModal = ({ onClose }) => {
  const { user, users, jobs, setJobs, setUsers } = useApp();
  const [testResults, setTestResults] = useState(null);
  const [isRunningTests, setIsRunningTests] = useState(false);

  const downloadText = (filename, text, mime = "text/plain;charset=utf-8") => {
    try {
      const blob = new Blob([text], { type: mime });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch {
      // ignore export errors in diagnostics
    }
  };

  const csvEscape = (v) => {
    const s = String(v ?? "");
    if (/[\",\n\r]/.test(s)) return `"${s.replace(/\"/g, '""')}"`;
    return s;
  };

  const toCSV = (rows, headers) => {
    const cols = headers && headers.length ? headers : (rows[0] ? Object.keys(rows[0]) : []);
    const lines = [
      cols.map(csvEscape).join(","),
      ...rows.map((r) => cols.map((c) => csvEscape(r?.[c])).join(",")),
    ];
    return "\ufeff" + lines.join("\n");
  };

  const getUserName = (id, fallback = "") => users.find((u) => u.id === id)?.name || fallback || "";

  const buildAcceptanceReport = () => {
    const rows = jobs
      .map((j) => normalizeJob(j))
      .filter((j) => j.status === "completed" || j.status === "closed");

    const items = rows.map((j) => {
      const photosCount = (j.photos || []).length;
      const signatureOk = Boolean(j.signature);
      const evidenceOk = photosCount > 0 && signatureOk;
      const metaOk = Array.isArray(j.photoMeta) ? j.photoMeta.length === photosCount : photosCount === 0;
      return {
        id: j.id,
        status: j.status,
        title: j.title,
        client: getUserName(j.clientId, j.clientName),
        engineer: getUserName(j.assignee),
        photos: photosCount,
        signature: signatureOk ? "Y" : "N",
        photo_meta_ok: metaOk ? "Y" : "N",
        evidence_ok: evidenceOk ? "Y" : "N",
        acceptance_flag: j.acceptanceFlag ? "Y" : "N",
        acceptance_note: j.acceptanceNote || "",
        acceptance_at: j.acceptanceAt || "",
        acceptance_by: getUserName(j.acceptanceBy),
        audit_status: j.auditStatus || "",
        audit_note: j.auditNote || "",
        audit_at: j.auditAt || "",
        audit_by: getUserName(j.auditBy),
      };
    });

    const abnormal = items.filter((i) => i.acceptance_flag === "Y").length;
    const closed = items.filter((i) => i.status === "closed").length;
    const completed = items.filter((i) => i.status === "completed").length;

    const issues = [];
    items.forEach((i) => {
      if (i.status === "completed" && i.evidence_ok !== "Y") issues.push(`工單 ${i.id}：完工但證據不足`);
      if (i.status === "closed" && (!i.acceptance_at || !i.acceptance_by)) issues.push(`工單 ${i.id}：結案但缺少驗收紀錄`);
      if (i.photo_meta_ok !== "Y") issues.push(`工單 ${i.id}：照片說明/點位數量不一致`);
    });

    return {
      generatedAt: new Date().toISOString(),
      totals: {
        total: items.length,
        closed,
        completed,
        abnormal,
      },
      issues,
      items,
    };
  };

  const runAutoTests = () => {
    setIsRunningTests(true);
    try {
      const results = [];

      const sampleClient = users.find((u) => String(u.role || "").startsWith("client")) || null;
      const sampleEng = users.find((u) => u.role === "engineer") || null;

      results.push({
        name: "樣本會員存在 (客戶/技師)",
        ok: Boolean(sampleClient) && Boolean(sampleEng),
        detail: `client=${sampleClient?.id || "none"}, engineer=${sampleEng?.id || "none"}`,
      });

      const sampleJob = normalizeJob({
        id: `T-${Date.now()}`,
        title: "自動測試工單",
        status: "open",
        clientId: sampleClient?.id || "client1",
        assignee: sampleEng?.id || "tech1",
        address: "台南市善化區南科三路100號",
        desc: "auto-test",
        laborBudget: 3000,
        materialBudget: 2000,
        messages: [],
      });

      const total = calcJobTotal(sampleJob);
      const dep = calcDeposit(total);
      const tail = calcTail(total);

      results.push({
        name: "金額拆分 (30/70)",
        ok: dep + tail === total,
        detail: `${formatCurrency(dep)} + ${formatCurrency(tail)} = ${formatCurrency(total)}`,
      });

      const jobWithMedia = normalizeJob({
        ...sampleJob,
        photos: ["data:image/png;base64,AAA"],
        signature: "data:image/png;base64,BBB",
      });

      results.push({
        name: "完工證據持久化 (照片/簽名)",
        ok: Array.isArray(jobWithMedia.photos) && jobWithMedia.photos.length === 1 && Boolean(jobWithMedia.signature),
        detail: `photos=${jobWithMedia.photos.length}, signature=${jobWithMedia.signature ? "yes" : "no"}`,
      });

      const jobWithMsg = normalizeJob({
        ...sampleJob,
        messages: [{ id: "M-1", fromId: "x", fromName: "x", text: "hi", ts: new Date().toISOString() }],
      });

      results.push({
        name: "訊息持久化 (messages)",
        ok: Array.isArray(jobWithMsg.messages) && jobWithMsg.messages.length === 1 && jobWithMsg.messages[0].text === "hi",
        detail: `messages=${jobWithMsg.messages.length}`,
      });

      const clientWallet = 10000;
      const engWallet = 0;
      const afterDeposit = clientWallet - dep;
      const afterTail = afterDeposit - tail;
      const engAfter = engWallet + total;

      results.push({
        name: "錢包流程 (訂金+尾款)",
        ok: afterTail === clientWallet - total && engAfter === total,
        detail: `client: ${formatCurrency(clientWallet)} -> ${formatCurrency(afterTail)}, eng: ${formatCurrency(engWallet)} -> ${formatCurrency(engAfter)}`,
      });

      const completedJobs = jobs.filter((j) => j.status === "completed" || j.status === "closed");
      const metaOk = completedJobs.every((j) => (Array.isArray(j.photos) ? (Array.isArray(j.photoMeta) ? j.photoMeta.length === j.photos.length : j.photos.length === 0) : true));
      results.push({
        name: "完工照片說明對齊 (photoMeta)",
        ok: metaOk,
        detail: metaOk ? "照片說明/點位筆數一致" : "存在照片與說明數量不一致",
      });

      const closedJobs = jobs.filter((j) => j.status === "closed");
      const acceptanceOk = closedJobs.every((j) => j.acceptanceAt && j.acceptanceBy);
      results.push({
        name: "驗收紀錄完整 (closed)",
        ok: acceptanceOk,
        detail: `closed=${closedJobs.length}`,
      });

      setTestResults(results);
    } finally {
      setIsRunningTests(false);
    }
  };

  const issues = [];
  const validStatus = new Set(["open", "active", "completed", "closed"]);

  if (!window.localStorage) issues.push("localStorage 不可用，資料將無法保存");

  users.forEach((u) => {
    if (!u.id) issues.push("有會員缺少 id");
    if (u.wallet !== undefined && Number.isNaN(Number(u.wallet))) issues.push(`會員錢包金額異常: ${u.name}`);
  });

  jobs.forEach((j) => {
    if (!j.id) issues.push("有工單缺少 id");
    if (!j.title) issues.push(`工單缺少標題: ${j.id}`);
    if (!validStatus.has(j.status)) issues.push(`工單狀態不合法: ${j.id} (${j.status})`);
    if (!j.clientId) issues.push(`工單缺少 clientId: ${j.id}`);

    const total = calcJobTotal(j);
    if (total <= 0) issues.push(`工單預算為 0: ${j.id}`);

    if (j.status === "completed") {
      if (!Array.isArray(j.photos) || j.photos.length === 0) issues.push(`已完工但缺少照片: ${j.id}`);
      if (!j.signature) issues.push(`已完工但缺少簽名: ${j.id}`);
    }
    if ((j.status === "completed" || j.status === "closed") && Array.isArray(j.photos)) {
      const metaOk = Array.isArray(j.photoMeta) ? j.photoMeta.length === j.photos.length : j.photos.length === 0;
      if (!metaOk) issues.push(`照片說明/點位數量不一致: ${j.id}`);
    }
    if (j.status === "closed") {
      if (!j.acceptanceAt || !j.acceptanceBy) issues.push(`已結案但缺少驗收紀錄: ${j.id}`);
    }
  });

  const fixData = () => {
    setUsers((prev) => prev.map((u) => ({ ...u, wallet: Number(u.wallet) || 0 })));
    setJobs((prev) => prev.map((j) => normalizeJob(j)));
  };

  return (
    <div className="fixed inset-0 z-[210] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[80vh] md:h-[75vh] shadow-2xl overflow-hidden flex flex-col">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center">
              <Icon name="bug" size={22} />
            </div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">系統自檢</h3>
              <p className="text-xs text-slate-400">{user ? `目前登入: ${user.name}` : "尚未登入"} | users: {users.length} | jobs: {jobs.length}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 overflow-y-auto flex-1">
          {issues.length === 0 ? (
            <div className="p-4 rounded-2xl bg-emerald-50 text-emerald-700 font-bold">未發現明顯資料或流程問題</div>
          ) : (
            <div className="space-y-2">
              {issues.map((t, i) => (
                <div key={i} className="p-3 rounded-xl bg-rose-50 text-rose-700 text-sm font-medium">{t}</div>
              ))}
            </div>
          )}

          {testResults ? (
            <div className="mt-6 space-y-2">
              <h4 className="text-sm font-bold text-slate-700">自動流程測試結果 (不修改資料)</h4>
              {testResults.map((r, i) => (
                <div key={i} className={`p-3 rounded-xl text-sm font-medium ${r.ok ? "bg-emerald-50 text-emerald-700" : "bg-rose-50 text-rose-700"}`}>
                  <div className="flex items-center justify-between">
                    <span>{r.name}</span>
                    <span className="font-num">{r.ok ? "PASS" : "FAIL"}</span>
                  </div>
                  {r.detail && (
                    <div className={`text-xs mt-1 ${r.ok ? "text-emerald-700/80" : "text-rose-700/80"}`}>{r.detail}</div>
                  )}
                </div>
              ))}
            </div>
          ) : (
            <div className="mt-6 text-xs text-slate-400">可按下下方「執行自動測試」做主要流程邏輯驗證 (不會修改你的資料)。</div>
          )}

          <div className="mt-6 bg-slate-50 border border-slate-200 rounded-2xl p-4">
            <div className="flex items-center justify-between flex-wrap gap-2">
              <div>
                <div className="text-sm font-bold text-slate-800">驗收流程測試報告輸出</div>
                <div className="text-xs text-slate-500 mt-1">輸出完工/驗收/稽核欄位完整度與異常清單</div>
              </div>
              <div className="flex gap-2">
                <button
                  onClick={() => {
                    const report = buildAcceptanceReport();
                    const stamp = new Date().toISOString().slice(0, 10);
                    downloadText(`acceptance_report_${stamp}.json`, JSON.stringify(report, null, 2), "application/json;charset=utf-8");
                  }}
                  className="btn btn-outline px-4 py-2 rounded-xl"
                >
                  匯出 JSON
                </button>
                <button
                  onClick={() => {
                    const report = buildAcceptanceReport();
                    const stamp = new Date().toISOString().slice(0, 10);
                    downloadText(`acceptance_report_${stamp}.csv`, toCSV(report.items), "text/csv;charset=utf-8");
                  }}
                  className="btn btn-outline px-4 py-2 rounded-xl"
                >
                  匯出 CSV
                </button>
              </div>
            </div>
          </div>

        </div>
        <div className="p-6 border-t border-slate-100 bg-white">
          <div className="grid grid-cols-1 md:grid-cols-3 gap-3">
            <button onClick={runAutoTests} className={`w-full btn btn-outline ${isRunningTests ? "opacity-50 pointer-events-none" : ""}`}>{isRunningTests ? "測試中..." : "執行自動測試"}</button>
            <button onClick={fixData} className="w-full btn btn-outline">嘗試修復資料</button>
            <button onClick={onClose} className="w-full btn btn-primary">關閉</button>
          </div>
        </div>
      </div>
    </div>
  );
};

