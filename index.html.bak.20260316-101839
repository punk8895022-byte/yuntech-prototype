          if (id === "jobs") {
            setNav("jobs");
            setShowInbox(false);
            setChatJob(null);
            setShowProfile(false);
            return;
          }
          if (id === "messages") {
            setNav("messages");
            setShowProfile(false);
            setChatJob(null);
            setShowInbox(true);
