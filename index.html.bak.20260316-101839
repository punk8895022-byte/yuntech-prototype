  const [showCreate, setShowCreate] = useState(false);
  const { addToast } = useToast();
  const [showInbox, setShowInbox] = useState(false);
  const [chatJob, setChatJob] = useState(null);
  const chatPeer = chatJob ? users.find((u) => u.id === chatJob.assignee) : null;

  const [showProfile, setShowProfile] = useState(false);
  const [nav, setNav] = useState("jobs");


  const myJobs = jobs.filter((j) => j.clientId === user.id);

  return (
    <div className="min-h-screen pb-32">
      {selectedJob && (
        <ProjectDetail
          job={selectedJob}
          user={user}
          onClose={() => setSelectedJob(null)}
          onUpdate={(u) => { setJobs((prev) => prev.map((j) => (j.id === u.id ? normalizeJob(u) : j))); setSelectedJob(normalizeJob(u)); }}
          addToast={addToast}
        />
      )}
      {showCreate && <ClientCreateJob onClose={() => setShowCreate(false)} />}

      {showInbox && (
        <ConversationsModal
          me={user}
          onClose={() => { setShowInbox(false); setNav("jobs"); }}
