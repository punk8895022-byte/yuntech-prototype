    setJobs((prev) => prev.map((j) => (selectedJobIds.has(j.id) ? normalizeJob({ ...j, status }) : j)));
    logAudit("bulk_update_jobs", `count=${ids.length} status=${status}`);
    addToast("已批次更新工單狀態", "success");
    setSelectedJobIds(new Set());
