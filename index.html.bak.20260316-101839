      <div className="p-6 pt-12 pb-20 bg-indigo-600 text-white rounded-b-[2.5rem] shadow-xl shadow-indigo-200 mb-6 relative overflow-hidden">
        <div className="absolute top-0 right-0 p-12 opacity-10"><Icon name="zap" size={120} /></div>
        <div className="flex justify-between items-center mb-6 relative z-10">
          <div><h1 className="font-bold text-lg">Hi, {user.name}</h1><p className="text-xs text-indigo-200">工程大小事，雲程幫你顧</p></div>
          <div className="flex items-center gap-3">
            <button onClick={() => setShowProfile(true)} className="p-2 rounded-xl bg-white/15 hover:bg-white/20 transition" title="編輯資料"><Icon name="user-cog" /></button>
            <button onClick={logout} title="登出"><Icon name="log-out" /></button>
          </div>
        </div>
        <button onClick={() => setShowCreate(true)} className="w-full bg-white text-indigo-600 p-4 rounded-2xl font-bold shadow-lg flex items-center justify-center gap-2 transform transition-transform active:scale-95 relative z-10">
          <div className="p-1 bg-indigo-100 rounded-full"><Icon name="plus" size={16} /></div>
          發布新需求
        </button>
      </div>

      <div className="px-6 space-y-4">
        <h3 className="font-bold text-slate-800">進行中案件</h3>
        {myJobs.map((j) => (
          <div key={j.id} onClick={() => setSelectedJob(j)} className="card-modern p-5 cursor-pointer">
            <div className="flex justify-between mb-2"><span className="text-xs bg-indigo-50 text-indigo-600 px-2 py-1 rounded font-bold">{j.status}</span></div>
            <h4 className="font-bold text-lg text-slate-800 mb-1">{j.title}</h4>
            <div className="flex justify-between text-xs text-slate-400 font-num"><span>{new Date(j.created_at).toLocaleDateString()}</span><span className="font-bold text-slate-800">${(j.laborBudget + j.materialBudget).toLocaleString()}</span></div>
          </div>
        ))}
