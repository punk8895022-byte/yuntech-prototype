// --- [Modules: Client] ---
const ClientCreateJob = ({ onClose }) => {
  const { user, addJob, updateUser } = useApp();
  const [form, setForm] = useState({
    title: "",
    type: "",
    address: user?.address || "",
    desc: "",
    labor: "",
    material: "",
    date: "",
    items: {},
    customItems: [],
  });
  const [isAiLoading, setIsAiLoading] = useState(false);

  const { addToast } = useToast();

  const currentSubItems = useMemo(() => {
    const category = PROJECT_CATEGORIES.find((c) => c.label === form.type);
    return category ? category.subItems : [];
  }, [form.type]);

  useEffect(() => {
    let laborTotal = 0;
    let materialTotal = 0;
    const descParts = [];

    const subById = new Map((currentSubItems || []).map((i) => [i.id, i]));

    Object.entries(form.items || {}).forEach(([id, qtyRaw]) => {
      const qty = Number(qtyRaw) || 0;
      if (qty <= 0) return;
      const item = subById.get(id);
      if (!item) return;
      materialTotal += (Number(item.price) || 0) * qty;
      laborTotal += (Number(item.labor) || 0) * qty;
      descParts.push(`${item.name} x${qty}`);
    });

    (form.customItems || []).forEach((ci) => {
      const name = String(ci.name || "").trim();
      const qty = Number(ci.qty) || 0;
      if (!name || qty <= 0) return;
      const mat = Number(ci.material) || 0;
      const lab = Number(ci.labor) || 0;
      materialTotal += mat * qty;
      laborTotal += lab * qty;
      descParts.push(`${name} x${qty}`);
    });

    if (descParts.length === 0) return;

    if (laborTotal > 0 || materialTotal > 0) {
      setForm((prev) => ({
        ...prev,
        labor: laborTotal,
        material: materialTotal,
        desc: descParts.join(", "),
      }));
    }
  }, [form.items, form.customItems, currentSubItems]);

  const handleItemChange = (id, delta) => {
    setForm((prev) => {
      const currentQty = prev.items[id] || 0;
      const newQty = Math.max(0, currentQty + delta);
      return { ...prev, items: { ...prev.items, [id]: newQty } };
    });
  };

  const addCustomItem = () => {
    const id = `CI-${Date.now()}`;
    setForm((prev) => ({
      ...prev,
      customItems: [
        ...(prev.customItems || []),
        { id, name: "", unit: "式", qty: 1, material: 0, labor: 0 },
      ],
    }));
  };

  const updateCustomItem = (idx, patch) => {
    setForm((prev) => ({
      ...prev,
      customItems: (prev.customItems || []).map((x, i) => (i === idx ? { ...x, ...patch } : x)),
    }));
  };

  const removeCustomItem = (idx) => {
    setForm((prev) => ({
      ...prev,
      customItems: (prev.customItems || []).filter((_, i) => i !== idx),
    }));
  };

  const handleSubmit = () => {
    if (!form.title || !form.type || !form.address) {
      addToast("請填寫完整資訊", "error");
      return;
    }

    const labor = Number.parseInt(form.labor, 10) || 0;
    const material = Number.parseInt(form.material, 10) || 0;
    const total = labor + material;

    if (total <= 0) {
      addToast("請設定預算金額", "error");
      return;
    }

    const deposit = calcDeposit(total);
    const tail = total - deposit;

    const wallet = Number(user.wallet) || 0;
    if (wallet < deposit) {
      addToast(`錢包餘額不足，訂金需要 ${formatCurrency(deposit)}`, "error");
      return;
    }

    updateUser({ ...user, wallet: wallet - deposit });

    addJob({
      id: `J-${Date.now()}`,
      title: form.title,
      type: form.type,
      address: form.address,
      desc: form.desc,
      scheduledDate: form.date,
      status: "open",
      clientId: user.id,
      clientName: user.name,
      laborBudget: labor,
      materialBudget: material,
      deposit_paid: true,
      depositAmount: deposit,
      tailAmount: tail,
      created_at: new Date().toISOString(),
      customItems: form.customItems || [],
      materials: [],
      photos: [],
      signature: null,
    });

    addToast(`訂金已支付 ${formatCurrency(deposit)}，已成功發案`, "success");
    onClose();
  };

  const handleAi = () => {
    setIsAiLoading(true);
    setTimeout(() => {
      setForm((p) => ({ ...p, labor: 3000, material: 2000 }));
      setIsAiLoading(false);
    }, 800);
  };

  const total = (Number.parseInt(form.labor, 10) || 0) + (Number.parseInt(form.material, 10) || 0);

  return (
    <div className="fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-md flex items-center justify-center p-4 animate-enter">
      <div className="bg-white w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh]">

        <div className="p-6 border-b border-slate-50 flex justify-between items-center">
          <h3 className="font-bold text-xl text-slate-800">發布需求</h3>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 space-y-4 overflow-y-auto flex-1">
          <div>
            <label className="text-xs font-bold text-slate-500 mb-2 block">工程類別</label>
            <div className="grid grid-cols-3 gap-2 mb-4">
              {PROJECT_CATEGORIES.map((cat) => (
                <button key={cat.id} onClick={() => setForm({ ...form, type: cat.label, items: {} })} className={`category-btn ${form.type === cat.label ? "active" : "inactive"}`}>
                  <Icon name={cat.icon} size={24} className="mb-1" /> <span className="text-[10px] font-bold">{cat.label}</span>
                </button>
              ))}
            </div>

            {currentSubItems.length > 0 && (
              <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 animate-slide-down">
                <label className="text-xs font-bold text-slate-500 mb-2 block">選擇細項 (自動計算)</label>
                <div className="space-y-2">
                  {currentSubItems.map((item) => (
                    <div key={item.id} className="flex justify-between items-center bg-white p-2 rounded-lg border border-slate-100">
                      <div>
                        <div className="text-sm font-bold text-slate-700">{item.name}</div>
                        <div className="text-xs text-slate-400">${item.price + item.labor} / {item.unit}</div>
                      </div>
                      <div className="flex items-center gap-3">
                        <button onClick={() => handleItemChange(item.id, -1)} className="w-6 h-6 rounded-full bg-slate-100">-</button>
                        <span className="w-4 text-center font-bold text-sm">{form.items[item.id] || 0}</span>
                        <button onClick={() => handleItemChange(item.id, 1)} className="w-6 h-6 rounded-full bg-indigo-100 text-indigo-600">+</button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 mt-4">
              <div className="flex items-center justify-between mb-2">
                <label className="text-xs font-bold text-slate-500 block">自訂常用項目 (可選)</label>
                <button onClick={addCustomItem} className="text-xs font-bold text-slate-700 bg-white px-3 py-1.5 rounded-full shadow-sm border border-slate-200 hover:bg-slate-50">+ 新增</button>
              </div>
              {(!form.customItems || form.customItems.length === 0) && <div className="text-sm text-slate-400">如果選單沒有符合的細項，可在這裡自行新增項目。</div>}
              <div className="space-y-2 mt-3">
                {(form.customItems || []).map((ci, idx) => {
                  const qty = Number(ci.qty) || 0;
                  const lineTotal = ((Number(ci.material) || 0) + (Number(ci.labor) || 0)) * qty;
                  return (
                    <div key={ci.id || idx} className="bg-white p-3 rounded-2xl border border-slate-100 space-y-2">
                      <div className="flex items-center gap-2">
                        <input className="input-modern py-2 flex-1" placeholder="項目名稱" value={ci.name} onChange={(e) => updateCustomItem(idx, { name: e.target.value })} />
                        <button onClick={() => removeCustomItem(idx)} className="px-3 py-2 rounded-xl bg-rose-50 text-rose-600 font-bold text-xs hover:bg-rose-100 border border-rose-100">刪除</button>
                      </div>
                      <div className="grid grid-cols-4 gap-2">
                        <input className="input-modern py-2" placeholder="單位" value={ci.unit} onChange={(e) => updateCustomItem(idx, { unit: e.target.value })} />
                        <input type="number" className="input-modern py-2 text-right font-num" placeholder="數量" value={ci.qty} onChange={(e) => updateCustomItem(idx, { qty: Number(e.target.value) })} />
                        <input type="number" className="input-modern py-2 text-right font-num" placeholder="材料/單位" value={ci.material} onChange={(e) => updateCustomItem(idx, { material: Number(e.target.value) })} />
                        <input type="number" className="input-modern py-2 text-right font-num" placeholder="工資/單位" value={ci.labor} onChange={(e) => updateCustomItem(idx, { labor: Number(e.target.value) })} />
                      </div>
                      <div className="text-xs text-slate-400 text-right">小計: {formatCurrency(lineTotal)}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          </div>

          <div className="space-y-3 pt-2 border-t border-slate-100">
            <input className="input-modern" placeholder="案件標題" value={form.title} onChange={(e) => setForm({ ...form, title: e.target.value })} />
            <input className="input-modern" placeholder="施工地址" value={form.address} onChange={(e) => setForm({ ...form, address: e.target.value })} />
            <div className="flex gap-3"><input type="datetime-local" className="input-modern" value={form.date} onChange={(e) => setForm({ ...form, date: e.target.value })} /></div>
            <textarea className="input-modern h-24 resize-none" placeholder="描述..." value={form.desc} onChange={(e) => setForm({ ...form, desc: e.target.value })} />
          </div>

          <div className="bg-indigo-50 p-5 rounded-3xl">
            <div className="flex justify-between items-center mb-4">
              <h4 className="font-bold text-indigo-900">預算設定</h4>
              {(!currentSubItems || currentSubItems.length === 0) && (
                <button onClick={handleAi} className="text-xs bg-white text-indigo-600 px-3 py-1.5 rounded-full font-bold shadow-sm flex items-center gap-1">
                  {isAiLoading ? <Icon name="loader-2" className="animate-spin" size={12} /> : <Icon name="sparkles" size={12} />} AI 估價
                </button>
              )}
            </div>
            <div className="grid grid-cols-2 gap-4">
              <input type="number" className="w-full p-2 rounded-lg text-right font-mono font-num" placeholder="工資" value={form.labor} onChange={(e) => setForm({ ...form, labor: e.target.value })} />
              <input type="number" className="w-full p-2 rounded-lg text-right font-mono font-num" placeholder="材料" value={form.material} onChange={(e) => setForm({ ...form, material: e.target.value })} />
            </div>
            <div className="mt-3 text-right text-indigo-900 font-bold text-lg font-num">總計: ${total.toLocaleString()}</div>
          </div>
        </div>

        <div className="p-6 border-t border-slate-50">
          <button onClick={handleSubmit} className="w-full btn btn-primary shadow-xl shadow-indigo-200">支付訂金 (30%) 並發布</button>
        </div>
      </div>
    </div>
  );
};


const CallModal = ({ name, phone, onClose, addToast }) => {
  const clean = String(phone || "");
  const tel = `tel:${clean.replace(/[^0-9+]/g, "")}`;

  const copy = async () => {
    try {
      await navigator.clipboard.writeText(clean);
      addToast("已複製電話", "success");
    } catch {
      // Fallback for non-secure contexts (file://)
      window.prompt("複製電話", clean);
    }
  };

  const dial = () => {
    if (!clean) {
      addToast("對方未提供電話", "error");
      return;
    }
    window.location.href = tel;
  };

  return (
    <div className="fixed inset-0 z-[170] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-md md:rounded-3xl rounded-t-3xl shadow-2xl overflow-hidden">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><Icon name="phone" size={20} /></div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">通話</h3>
              <p className="text-xs text-slate-400">{name || "對方"}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 space-y-4">
          <div className="card-modern p-5">
            <div className="text-xs font-bold text-slate-400 uppercase mb-2">電話</div>
            <div className="text-2xl font-bold text-slate-900 font-num">{clean || "未提供"}</div>
          </div>

          <div className="grid grid-cols-2 gap-3">
            <button onClick={copy} className="btn btn-outline py-3 rounded-xl">複製</button>
            <button onClick={dial} className="btn btn-primary py-3 rounded-xl">撥打</button>
          </div>
        </div>
      </div>
    </div>
  );
};

const ChatModal = ({ job, me, peer, onUpdate, onClose }) => {
  const [draft, setDraft] = useState("");
  const listRef = React.useRef(null);

  const messages = Array.isArray(job.messages) ? job.messages : [];

  useEffect(() => {
    const el = listRef.current;
    if (!el) return;
    el.scrollTop = el.scrollHeight;
  }, [messages.length]);

  const send = () => {
    const text = draft.trim();
    if (!text) return;

    const msg = {
      id: `M-${Date.now()}`,
      fromId: me.id,
      fromName: me.name,
      text,
      ts: new Date().toISOString(),
    };

    onUpdate({ ...job, messages: [...messages, msg] });
    setDraft("");
  };

  return (
    <div className="fixed inset-0 z-[175] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[85vh] md:h-[75vh] shadow-2xl overflow-hidden flex flex-col">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center"><Icon name="message-square" size={20} /></div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">訊息</h3>
              <p className="text-xs text-slate-400">{peer?.name || "對方"} · {job.title}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div ref={listRef} className="flex-1 overflow-y-auto p-6 space-y-3 bg-slate-50">
          {messages.length === 0 && <div className="text-sm text-slate-400 text-center">尚無訊息，輸入內容開始對話。</div>}
          {messages.map((m) => {
            const mine = m.fromId === me.id;
            return (
              <div key={m.id} className={`flex ${mine ? "justify-end" : "justify-start"}`}>
                <div className={`max-w-[80%] p-3 rounded-2xl text-sm shadow-sm ${mine ? "bg-indigo-600 text-white" : "bg-white text-slate-700"}`}>
                  <div className={`text-[10px] mb-1 ${mine ? "text-indigo-100" : "text-slate-400"}`}>{mine ? "我" : (m.fromName || "對方")}</div>
                  <div className="whitespace-pre-wrap leading-relaxed">{m.text}</div>
                </div>
              </div>
            );
          })}
        </div>

        <div className="p-4 border-t bg-white">
          <div className="flex gap-2">
            <input className="input-modern flex-1" placeholder="輸入訊息..." value={draft} onChange={(e) => setDraft(e.target.value)} onKeyDown={(e) => { if (e.key === "Enter") send(); }} />
            <button onClick={send} className="btn btn-primary px-5">送出</button>
          </div>
        </div>
      </div>
    </div>
  );
};

const ConversationsModal = ({ me, onClose, onOpen }) => {
  const { jobs, users } = useApp();

  const relevant = me?.role === "engineer"
    ? jobs.filter((j) => j.assignee === me.id)
    : jobs.filter((j) => j.clientId === me.id);

  const rows = relevant
    .map((j) => {
      const peer = me?.role === "engineer"
        ? users.find((u) => u.id === j.clientId)
        : users.find((u) => u.id === j.assignee);
      const msgs = Array.isArray(j.messages) ? j.messages : [];
      const last = msgs.length > 0 ? msgs[msgs.length - 1] : null;
      const lastTs = last?.ts || j.created_at || "";
      const preview = last?.text ? String(last.text).slice(0, 40) : "尚無訊息";
      return { job: j, peer, lastTs, preview };
    })
    .filter((r) => Boolean(r.peer))
    .sort((a, b) => String(b.lastTs).localeCompare(String(a.lastTs)));

  return (
    <div className="fixed inset-0 z-[176] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[85vh] md:h-[75vh] shadow-2xl overflow-hidden flex flex-col">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center"><Icon name="message-square" size={20} /></div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">訊息</h3>
              <p className="text-xs text-slate-400">快速開啟對話</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-4 overflow-y-auto flex-1 bg-slate-50">
          {rows.length === 0 ? (
            <div className="p-6 text-center text-sm text-slate-400 bg-white border border-slate-200 rounded-2xl">
              目前沒有可開啟的對話 (需要已媒合的案件)
            </div>
          ) : (
            <div className="space-y-3">
              {rows.map((r) => (
                <button
                  key={r.job.id}
                  onClick={() => onOpen(r.job)}
                  className="w-full text-left card-modern p-4 hover:border-indigo-300"
                >
                  <div className="flex items-center justify-between gap-3">
                    <div className="min-w-0">
                      <div className="text-sm font-bold text-slate-900 truncate">{r.peer?.name || "對方"} · {r.job.title}</div>
                      <div className="text-xs text-slate-500 mt-1 truncate">{r.preview}</div>
                    </div>
                    <div className="text-[10px] text-slate-400 font-num shrink-0">{r.lastTs ? new Date(r.lastTs).toLocaleString() : ""}</div>
                  </div>
                </button>
              ))}
            </div>
          )}
        </div>

        <div className="p-6 border-t border-slate-100 bg-white">
          <button onClick={onClose} className="w-full btn btn-outline">關閉</button>
        </div>
      </div>
    </div>
  );
};

const ProjectDetail = ({ job, user, onClose, onUpdate, addToast }) => {
  const isEng = user.role === "engineer";
  const { users, updateUser } = useApp();

  const techInfo = users.find((u) => u.id === job.assignee);

  
  const peerUser = isEng ? users.find((u) => u.id === job.clientId) : users.find((u) => u.id === job.assignee);
  const peerPhone = peerUser?.phone || "";

  const [showChat, setShowChat] = useState(false);
  const [showCall, setShowCall] = useState(false);
const total = calcJobTotal(job);
  const deposit = Number(job.depositAmount) || calcDeposit(total);
  const tail = Number(job.tailAmount) || (total - deposit);
  const jobPhotos = Array.isArray(job.photos) ? job.photos : [];
  const jobMaterialSum = (Array.isArray(job.materials) ? job.materials : []).reduce(
    (acc, m) => acc + (Number(m.price) || 0) * (Number(m.qty) || 0),
    0
  );
  const evidenceOk = jobPhotos.length > 0 && Boolean(job.signature);

  const [materials, setMaterials] = useState(job.materials || []);
  const [photos, setPhotos] = useState(job.photos || []);
  const [photoMeta, setPhotoMeta] = useState(
    Array.isArray(job.photoMeta) && job.photoMeta.length > 0
      ? job.photoMeta
      : (job.photos || []).map(() => ({ note: "", mark: "" }))
  );
  const [signature, setSignature] = useState(job.signature || null);
  const [acceptChecked, setAcceptChecked] = useState(false);
  const [acceptanceNote, setAcceptanceNote] = useState(job.acceptanceNote || "");
  const [acceptanceFlag, setAcceptanceFlag] = useState(Boolean(job.acceptanceFlag));
  const [photoViewerOpen, setPhotoViewerOpen] = useState(false);
  const [photoViewerIndex, setPhotoViewerIndex] = useState(0);
  const [photoViewerList, setPhotoViewerList] = useState([]);
  const [photoViewerMeta, setPhotoViewerMeta] = useState([]);
  const [showBOM, setShowBOM] = useState(false);

  const [showCustomMat, setShowCustomMat] = useState(false);
  const [customMat, setCustomMat] = useState({ name: "", unit: "式", price: "", qty: 1 });
  const openMaps = () => {
    if (!job.address) return;
    const w = window.open(mapsUrlForAddress(job.address), "_blank", "noopener,noreferrer");
    if (!w) addToast("瀏覽器阻擋了彈出視窗，請允許後再試一次", "error");
  };

  const handleAction = (action) => {
    if (action === "take") {
      onUpdate({ ...job, status: "active", assignee: user.id });
      addToast("接案成功", "success");
    }

    if (action === "arrive") {
      onUpdate({ ...job, techArrived: true, techArrivedAt: new Date().toISOString() });
      addToast("抵達打卡成功", "success");
    }

    if (action === "pay") {
      if (!evidenceOk) {
        addToast("驗收資料不足，請確認照片與簽名", "error");
        return;
      }
      if (!acceptChecked) {
        addToast("請先勾選驗收確認", "error");
        return;
      }
      const client = users.find((u) => u.id === job.clientId);
      const tech = users.find((u) => u.id === job.assignee);

      if (!client) {
        addToast("找不到客戶資料", "error");
        return;
      }
      if (!tech) {
        addToast("找不到技師資料", "error");
        return;
      }

      const clientWallet = Number(client.wallet) || 0;
      if (clientWallet < tail) {
        addToast(`錢包餘額不足，尾款需要 ${formatCurrency(tail)}`, "error");
        return;
      }

      updateUser({ ...client, wallet: clientWallet - tail });
      updateUser({ ...tech, wallet: (Number(tech.wallet) || 0) + total });

      onUpdate({
        ...job,
        status: "closed",
        paidAt: new Date().toISOString(),
        tail_paid: true,
        releasedTotal: total,
        acceptanceNote,
        acceptanceFlag,
        acceptanceAt: new Date().toISOString(),
        acceptanceBy: user?.id || null,
      });
      addToast("驗收付款完成，案件結案", "success");
      onClose();
    }
  };

  const updateMatQty = (idx, delta) => {
    setMaterials((prev) =>
      prev
        .map((m, i) => {
          if (i !== idx) return m;
          const nextQty = Math.max(0, (Number(m.qty) || 0) + delta);
          return { ...m, qty: nextQty };
        })
        .filter((m) => (Number(m.qty) || 0) > 0)
    );
  };

  const updateMatPrice = (idx, nextPrice) => {
    const price = Number(nextPrice) || 0;
    setMaterials((prev) => prev.map((m, i) => (i === idx ? { ...m, price } : m)));
  };

  const addMat = (m) => {
    setMaterials((prev) => {
      const idx = prev.findIndex((x) => x.id === m.id);
      if (idx >= 0) {
        return prev.map((x, i) => (i === idx ? { ...x, qty: (Number(x.qty) || 1) + 1 } : x));
      }
      return [...prev, { ...m, qty: 1 }];
    });
    setShowBOM(false);
  };

  const addCustomMat = () => {
    const name = String(customMat.name || "").trim();
    const unit = String(customMat.unit || "").trim() || "式";
    const price = Number(customMat.price) || 0;
    const qty = Math.max(1, Number(customMat.qty) || 1);

    if (!name) {
      addToast("請輸入耗材名稱", "error");
      return;
    }
    if (price <= 0) {
      addToast("請輸入正確單價", "error");
      return;
    }

    setMaterials((prev) => [...prev, { id: `CM-${Date.now()}`, name, unit, price, qty }]);
    setCustomMat({ name: "", unit: "式", price: "", qty: 1 });
    setShowCustomMat(false);
  };

  const handlePhoto = (e) => {
    const files = Array.from(e.target.files || []);
    if (files.length === 0) return;

    files.forEach((file) => {
      const r = new FileReader();
      r.onload = (v) => {
        setPhotos((prev) => [...prev, v.target.result]);
        setPhotoMeta((prev) => [...prev, { note: "", mark: "" }]);
      };
      r.readAsDataURL(file);
    });
  };

  const removePhoto = (idx) => {
    setPhotos((prev) => prev.filter((_, i) => i !== idx));
    setPhotoMeta((prev) => prev.filter((_, i) => i !== idx));
  };

  const openPhotoViewer = (list, idx, meta = []) => {
    if (!Array.isArray(list) || list.length === 0) return;
    setPhotoViewerList(list);
    setPhotoViewerIndex(Math.max(0, Math.min(idx, list.length - 1)));
    setPhotoViewerMeta(Array.isArray(meta) ? meta : []);
    setPhotoViewerOpen(true);
  };

  const updatePhotoMeta = (idx, patch) => {
    setPhotoMeta((prev) => prev.map((m, i) => (i === idx ? { ...m, ...patch } : m)));
  };

  const materialSum = materials.reduce((acc, m) => acc + (Number(m.price) || 0) * (Number(m.qty) || 0), 0);

  const submit = () => {
    if (!job.techArrived) {
      addToast("請先抵達打卡，再送出報告", "error");
      return;
    }
    if (photos.length === 0) {
      addToast("請至少上傳 1 張完工照片", "error");
      return;
    }
    if (!signature) {
      addToast("請先完成客戶簽名", "error");
      return;
    }

      onUpdate({
        ...job,
        status: "completed",
        materials,
        photos,
        photoMeta,
        signature,
        reportSubmittedAt: new Date().toISOString(),
        materialSum,
      });
    addToast("報告送出，等待客戶驗收", "success");
    onClose();
  };

  const canSubmit = Boolean(job.techArrived) && photos.length > 0 && Boolean(signature);

  return (
    <div className="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[95vh] md:h-[85vh] flex flex-col shadow-2xl overflow-hidden">

        {showCall && <CallModal name={peerUser?.name} phone={peerPhone} addToast={addToast} onClose={() => setShowCall(false)} />}
        {showChat && <ChatModal job={job} me={user} peer={peerUser} onUpdate={onUpdate} onClose={() => setShowChat(false)} />}
        {photoViewerOpen && (
          <div className="fixed inset-0 z-[200] bg-black/80 flex items-center justify-center p-4">
            <div className="relative w-full max-w-3xl">
              <button onClick={() => setPhotoViewerOpen(false)} className="absolute -top-3 -right-3 w-10 h-10 rounded-full bg-white text-slate-700 shadow flex items-center justify-center">×</button>
              <div className="bg-white rounded-2xl overflow-hidden">
                <img src={photoViewerList[photoViewerIndex]} className="w-full max-h-[70vh] object-contain bg-slate-900" />
                <div className="p-4 space-y-3">
                  {photoViewerMeta[photoViewerIndex] && (photoViewerMeta[photoViewerIndex].note || photoViewerMeta[photoViewerIndex].mark) && (
                    <div className="text-xs text-slate-600">
                      {photoViewerMeta[photoViewerIndex].note ? `說明：${photoViewerMeta[photoViewerIndex].note}` : ""}
                      {photoViewerMeta[photoViewerIndex].mark ? `　點位：${photoViewerMeta[photoViewerIndex].mark}` : ""}
                    </div>
                  )}
                  <div className="flex items-center justify-between text-sm text-slate-600">
                    <button
                      onClick={() => setPhotoViewerIndex((i) => Math.max(0, i - 1))}
                      className={`px-3 py-2 rounded-lg border ${photoViewerIndex === 0 ? "opacity-50 pointer-events-none" : "hover:bg-slate-50"}`}
                    >
                      上一張
                    </button>
                    <span>{photoViewerIndex + 1} / {photoViewerList.length}</span>
                    <button
                      onClick={() => setPhotoViewerIndex((i) => Math.min(photoViewerList.length - 1, i + 1))}
                      className={`px-3 py-2 rounded-lg border ${photoViewerIndex === photoViewerList.length - 1 ? "opacity-50 pointer-events-none" : "hover:bg-slate-50"}`}
                    >
                      下一張
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
        )}


        <div className="p-6 bg-white border-b border-slate-50 flex justify-between items-center">
          <div>
            <span className="bg-indigo-50 text-indigo-600 px-2 py-1 rounded text-xs font-bold">{job.status}</span>
            <h2 className="text-xl font-bold mt-1">{job.title}</h2>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100 text-slate-500"><Icon name="x" /></button>
        </div>

        <div className="flex-1 overflow-y-auto p-6 pb-32 space-y-6">
          {(job.assignee || user.role.startsWith("client")) && (
            <div className="grid grid-cols-3 gap-3">
              <button
                onClick={() => (peerUser ? setShowCall(true) : addToast("尚未媒合技師，暫無法通話", "error"))}
                className={`p-4 bg-indigo-50 text-indigo-700 rounded-2xl font-bold flex flex-col items-center gap-2 hover:bg-indigo-100 ${
                  !peerUser ? "opacity-50 pointer-events-none" : ""
                }`}
              >
                <Icon name="phone" /> 通話
              </button>
              <button
                onClick={() => (peerUser ? setShowChat(true) : addToast("尚未媒合技師，暫無法訊息", "error"))}
                className={`p-4 bg-slate-50 text-slate-700 rounded-2xl font-bold flex flex-col items-center gap-2 hover:bg-slate-100 ${
                  !peerUser ? "opacity-50 pointer-events-none" : ""
                }`}
              >
                <Icon name="message-square" /> 訊息
              </button>
              <button onClick={openMaps} className="p-4 bg-emerald-50 text-emerald-700 rounded-2xl font-bold flex flex-col items-center gap-2 hover:bg-emerald-100"><Icon name="navigation" /> 導航</button>
            </div>
          )}

          <div className="bg-white border border-slate-100 p-5 rounded-2xl space-y-3 shadow-sm">
            <div className="flex gap-3 text-sm text-slate-600"><Icon name="map-pin" size={18} /> {job.address}</div>
            <div className="flex gap-3 text-sm text-slate-600"><Icon name="file-text" size={18} /> {job.desc}</div>

            <div className="border-t pt-3 space-y-2">
              <div className="flex justify-between font-bold text-lg font-num"><span>預算總額</span><span>{formatCurrency(total)}</span></div>
              <div className="flex justify-between text-sm text-slate-600"><span>已收訂金 (30%)</span><span>{formatCurrency(deposit)}</span></div>
              <div className="flex justify-between text-sm text-slate-600"><span>待收尾款 (未結案)</span><span>{formatCurrency(tail)}</span></div>
            </div>
          </div>

          {techInfo && !isEng && (
            <div className="bg-white p-4 rounded-xl border border-slate-200 card-modern">
              <h4 className="text-xs font-bold text-slate-400 uppercase mb-3">接案師傅資訊</h4>
              <div className="flex items-center gap-3">
                <div className="w-12 h-12 rounded-full bg-slate-200 flex items-center justify-center font-bold text-lg text-slate-600">{techInfo.avatar}</div>
                <div className="flex-1"><p className="font-bold text-lg">{techInfo.name}</p><p className="text-xs text-slate-500">{techInfo.title} • {techInfo.experience}</p></div>
                <div className="text-right"><p className="text-yellow-500 font-bold flex items-center gap-1"><Icon name="star" size={14} /> {techInfo.rating}</p></div>
              </div>
            </div>
          )}

          {!isEng && (job.status === "completed" || job.status === "closed") && (
            <div className="bg-white p-5 rounded-2xl border border-slate-100 shadow-sm space-y-4">
              <h4 className="font-bold text-slate-800 flex items-center gap-2"><Icon name="clipboard-check" /> 完工證據</h4>

                {job.photos && job.photos.length > 0 && (
                  <div>
                    <div className="text-xs font-bold text-slate-400 uppercase mb-2">完工照片</div>
                    <div className="flex gap-2 overflow-x-auto pb-2">
                      {job.photos.map((p, i) => (
                        <div key={i} className="w-24 shrink-0">
                          <button onClick={() => openPhotoViewer(job.photos, i, job.photoMeta || [])} className="w-24 h-24 rounded-xl overflow-hidden border">
                            <img src={p} className="w-24 h-24 object-cover" />
                          </button>
                          {job.photoMeta && job.photoMeta[i] && (
                            <div className="mt-1 text-[10px] text-slate-500">
                              {job.photoMeta[i].note ? `說明: ${job.photoMeta[i].note}` : ""}
                              {job.photoMeta[i].mark ? ` / 點位: ${job.photoMeta[i].mark}` : ""}
                            </div>
                          )}
                        </div>
                      ))}
                    </div>
                  </div>
                )}

                {job.signature && (
                  <div>
                    <div className="text-xs font-bold text-slate-400 uppercase mb-2">客戶簽名</div>
                    <img src={job.signature} className="w-full max-w-md rounded-xl border bg-white" />
                  </div>
                )}

                <div className="bg-slate-50 border border-slate-200 rounded-2xl p-4">
                  <div className="text-xs font-bold text-slate-500 mb-2">驗收狀況</div>
                  <div className="grid grid-cols-2 gap-2 text-sm">
                    <div className={`px-3 py-2 rounded-lg ${jobPhotos.length > 0 ? "bg-emerald-50 text-emerald-700" : "bg-rose-50 text-rose-700"}`}>
                      完工照片 {jobPhotos.length > 0 ? "已上傳" : "缺少"}
                    </div>
                    <div className={`px-3 py-2 rounded-lg ${job.signature ? "bg-emerald-50 text-emerald-700" : "bg-rose-50 text-rose-700"}`}>
                      客戶簽名 {job.signature ? "已完成" : "缺少"}
                    </div>
                    <div className="px-3 py-2 rounded-lg bg-slate-100 text-slate-600">
                      耗材明細 {(job.materials || []).length} 項
                    </div>
                    <div className="px-3 py-2 rounded-lg bg-slate-100 text-slate-600">
                      耗材金額 {formatCurrency(jobMaterialSum)}
                    </div>
                  </div>
                  {job.status === "completed" && (
                    <div className="mt-3 space-y-2">
                      <label className="flex items-center gap-2 text-sm text-slate-600">
                        <input type="checkbox" checked={acceptChecked} onChange={(e) => setAcceptChecked(e.target.checked)} />
                        我已確認完工照片與簽名，並同意驗收付款
                      </label>
                      <label className="flex items-center gap-2 text-sm text-slate-600">
                        <input type="checkbox" checked={acceptanceFlag} onChange={(e) => setAcceptanceFlag(e.target.checked)} />
                        發現異常 (將標記給管理端)
                      </label>
                      <textarea
                        className="input-modern h-20 resize-none"
                        placeholder="驗收備註 (可填寫問題、補件需求)"
                        value={acceptanceNote}
                        onChange={(e) => setAcceptanceNote(e.target.value)}
                      />
                    </div>
                  )}
                  {job.status === "closed" && (
                    <div className="mt-3 text-sm text-slate-600">
                      <div>異常標記：{job.acceptanceFlag ? "是" : "否"}</div>
                      <div className="mt-1">驗收備註：{job.acceptanceNote ? job.acceptanceNote : "無"}</div>
                    </div>
                  )}
                </div>
              </div>
            )}

          {isEng && job.status === "active" && (
            <div className="space-y-6">
              {!job.techArrived && (
                <div className="bg-amber-50 border border-amber-100 p-4 rounded-2xl text-amber-700 text-sm font-medium">
                  請先完成抵達打卡，才能送出完工報告。
                </div>
              )}

              {!job.techArrived && <button onClick={() => handleAction("arrive")} className="w-full btn btn-primary py-4 shadow-lg shadow-indigo-200">📍 我已抵達，打卡通知</button>}

              <div className="bg-slate-50 p-5 rounded-3xl border border-slate-100">
                <div className="flex justify-between items-center mb-4">
                  <h3 className="font-bold text-slate-800 flex items-center gap-2"><Icon name="package" /> 耗材紀錄</h3>
                  <div className="flex items-center gap-2">
                    <button onClick={() => setShowBOM(!showBOM)} className="text-xs font-bold text-indigo-600 bg-white px-3 py-1.5 rounded-full shadow-sm">+ 常用庫</button>
                    <button onClick={() => setShowCustomMat((v) => !v)} className="text-xs font-bold text-slate-700 bg-white px-3 py-1.5 rounded-full shadow-sm border border-slate-200 hover:bg-slate-50">+ 自訂耗材</button>
                  </div>
                </div>

                {showBOM && (
                  <div className="grid grid-cols-1 gap-2 mb-4 max-h-48 overflow-y-auto">
                    {WEAK_CURRENT_SUPPLIES.map((m) => (
                      <button key={m.id} onClick={() => addMat(m)} className="bg-white p-3 rounded-xl text-left text-xs font-bold text-slate-700 shadow-sm flex justify-between"><span>{m.name}</span><span className="text-slate-400">${m.price}</span></button>
                    ))}
                  </div>
                )}

                {showCustomMat && (
                  <div className="bg-white p-4 rounded-2xl border border-slate-200 mb-4 animate-slide-down">
                    <div className="grid grid-cols-2 gap-2">
                      <input className="input-modern py-2" placeholder="耗材名稱" value={customMat.name} onChange={(e) => setCustomMat((p) => ({ ...p, name: e.target.value }))} />
                      <input className="input-modern py-2" placeholder="單位" value={customMat.unit} onChange={(e) => setCustomMat((p) => ({ ...p, unit: e.target.value }))} />
                      <input type="number" className="input-modern py-2 text-right font-num" placeholder="單價" value={customMat.price} onChange={(e) => setCustomMat((p) => ({ ...p, price: e.target.value }))} />
                      <input type="number" className="input-modern py-2 text-right font-num" placeholder="數量" value={customMat.qty} onChange={(e) => setCustomMat((p) => ({ ...p, qty: Number(e.target.value) }))} />
