            <div className="p-4 bg-blue-50 text-blue-600 rounded-2xl group-hover:scale-110 transition-transform"><Icon name="user" /></div>
            <div><h3 className="font-bold text-lg">一般客戶</h3><p className="text-xs text-slate-400">居家修繕、個人需求</p></div>
          </button>
          <button onClick={() => { setRole("client_business"); setView("login"); }} className="card-modern p-6 flex items-center gap-4 hover:border-indigo-400 group text-left">
            <div className="p-4 bg-indigo-50 text-indigo-600 rounded-2xl group-hover:scale-110 transition-transform"><Icon name="building-2" /></div>
            <div><h3 className="font-bold text-lg">企業用戶</h3><p className="text-xs text-slate-400">公司統編、月結服務</p></div>
          </button>
          <button onClick={() => { setRole("engineer"); setView("login"); }} className="card-modern p-6 flex items-center gap-4 hover:border-indigo-400 group text-left">
            <div className="p-4 bg-emerald-50 text-emerald-600 rounded-2xl group-hover:scale-110 transition-transform"><Icon name="wrench" /></div>
            <div><h3 className="font-bold text-lg">工程師 / 技師</h3><p className="text-xs text-slate-400">接案媒合、完工回報</p></div>
