      {chatJob && chatPeer && (
        <ChatModal
          job={chatJob}
          me={user}
          peer={chatPeer}
          onUpdate={(u) => {
            setJobs((prev) => prev.map((j) => (j.id === u.id ? normalizeJob(u) : j)));
            setChatJob(normalizeJob(u));
            setSelectedJob((prev) => (prev && prev.id === u.id ? normalizeJob(u) : prev));
