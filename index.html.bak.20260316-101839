                <button onClick={() => setMode("replace")} className={`px-4 py-2 rounded-xl font-bold text-sm border ${mode === "replace" ? "bg-rose-50 text-rose-700 border-rose-200" : "bg-white text-slate-600 border-slate-200"}`}>取代</button>
