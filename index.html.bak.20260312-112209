                >
                  <div className="flex items-center justify-between gap-3">
                    <div className="min-w-0">
                      <div className="text-sm font-bold text-slate-900 truncate">{r.peer?.name || "對方"} · {r.job.title}</div>
                      <div className="text-xs text-slate-500 mt-1 truncate">{r.preview}</div>
                    </div>
                    <div className="text-[10px] text-slate-400 font-num shrink-0">{r.lastTs ? new Date(r.lastTs).toLocaleString() : ""}</div>
                  </div>
                </button>
              ))}
            </div>
          )}
        </div>

        <div className="p-6 border-t border-slate-100 bg-white">
          <button onClick={onClose} className="w-full btn btn-outline">關閉</button>
        </div>
      </div>
    </div>
  );
};

const ProjectDetail = ({ job, user, onClose, onUpdate, addToast }) => {
  const isEng = user.role === "engineer";
  const { users, updateUser } = useApp();

  const techInfo = users.find((u) => u.id === job.assignee);

  
  const peerUser = isEng ? users.find((u) => u.id === job.clientId) : users.find((u) => u.id === job.assignee);
  const peerPhone = peerUser?.phone || "";

  const [showChat, setShowChat] = useState(false);
  const [showCall, setShowCall] = useState(false);
const total = calcJobTotal(job);
  const deposit = Number(job.depositAmount) || calcDeposit(total);
  const tail = Number(job.tailAmount) || (total - deposit);

  const [materials, setMaterials] = useState(job.materials || []);
  const [photos, setPhotos] = useState(job.photos || []);
  const [signature, setSignature] = useState(job.signature || null);
  const [showBOM, setShowBOM] = useState(false);

  const openMaps = () => {
    if (!job.address) return;
    const w = window.open(mapsUrlForAddress(job.address), "_blank", "noopener,noreferrer");
    if (!w) addToast("瀏覽器阻擋了彈出視窗，請允許後再試一次", "error");
  };

  const handleAction = (action) => {
    if (action === "take") {
      onUpdate({ ...job, status: "active", assignee: user.id });
      addToast("接案成功", "success");
    }

    if (action === "arrive") {
      onUpdate({ ...job, techArrived: true, techArrivedAt: new Date().toISOString() });
      addToast("抵達打卡成功", "success");
    }

    if (action === "pay") {
      const client = users.find((u) => u.id === job.clientId);
      const tech = users.find((u) => u.id === job.assignee);

      if (!client) {
        addToast("找不到客戶資料", "error");
        return;
      }
      if (!tech) {
        addToast("找不到技師資料", "error");
        return;
      }

      const clientWallet = Number(client.wallet) || 0;
      if (clientWallet < tail) {
        addToast(`錢包餘額不足，尾款需要 ${formatCurrency(tail)}`, "error");
        return;
      }

      updateUser({ ...client, wallet: clientWallet - tail });
      updateUser({ ...tech, wallet: (Number(tech.wallet) || 0) + total });

      onUpdate({ ...job, status: "closed", paidAt: new Date().toISOString(), tail_paid: true, releasedTotal: total });
      addToast("驗收付款完成，案件結案", "success");
      onClose();
    }
  };

  const updateMatQty = (idx, delta) => {
    setMaterials((prev) =>
      prev
        .map((m, i) => {
          if (i !== idx) return m;
          const nextQty = Math.max(0, (Number(m.qty) || 0) + delta);
          return { ...m, qty: nextQty };
        })
        .filter((m) => (Number(m.qty) || 0) > 0)
    );
  };

  const addMat = (m) => {
    setMaterials((prev) => {
      const idx = prev.findIndex((x) => x.id === m.id);
      if (idx >= 0) {
        return prev.map((x, i) => (i === idx ? { ...x, qty: (Number(x.qty) || 1) + 1 } : x));
      }
      return [...prev, { ...m, qty: 1 }];
    });
    setShowBOM(false);
  };

  const handlePhoto = (e) => {
    const files = Array.from(e.target.files || []);
    if (files.length === 0) return;

    files.forEach((file) => {
      const r = new FileReader();
      r.onload = (v) => setPhotos((prev) => [...prev, v.target.result]);
      r.readAsDataURL(file);
    });
  };

  const removePhoto = (idx) => {
    setPhotos((prev) => prev.filter((_, i) => i !== idx));
  };

  const materialSum = materials.reduce((acc, m) => acc + (Number(m.price) || 0) * (Number(m.qty) || 0), 0);

  const submit = () => {
    if (!job.techArrived) {
      addToast("請先抵達打卡，再送出報告", "error");
      return;
    }
    if (photos.length === 0) {
      addToast("請至少上傳 1 張完工照片", "error");
      return;
    }
    if (!signature) {
      addToast("請先完成客戶簽名", "error");
      return;
    }

    onUpdate({
      ...job,
      status: "completed",
      materials,
      photos,
      signature,
      reportSubmittedAt: new Date().toISOString(),
      materialSum,
    });
    addToast("報告送出，等待客戶驗收", "success");
    onClose();
  };

  const canSubmit = Boolean(job.techArrived) && photos.length > 0 && Boolean(signature);

  return (
    <div className="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[95vh] md:h-[85vh] flex flex-col shadow-2xl overflow-hidden">

        {showCall && <CallModal name={peerUser?.name} phone={peerPhone} addToast={addToast} onClose={() => setShowCall(false)} />}
        {showChat && <ChatModal job={job} me={user} peer={peerUser} onUpdate={onUpdate} onClose={() => setShowChat(false)} />}


        <div className="p-6 bg-white border-b border-slate-50 flex justify-between items-center">
          <div>
            <span className="bg-indigo-50 text-indigo-600 px-2 py-1 rounded text-xs font-bold">{job.status}</span>
            <h2 className="text-xl font-bold mt-1">{job.title}</h2>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100 text-slate-500"><Icon name="x" /></button>
        </div>

        <div className="flex-1 overflow-y-auto p-6 pb-32 space-y-6">
          {(job.assignee || user.role.startsWith("client")) && (
            <div className="grid grid-cols-3 gap-3">
              <button
                onClick={() => (peerUser ? setShowCall(true) : addToast("尚未媒合技師，暫無法通話", "error"))}
                className={`p-4 bg-indigo-50 text-indigo-700 rounded-2xl font-bold flex flex-col items-center gap-2 hover:bg-indigo-100 ${
                  !peerUser ? "opacity-50 pointer-events-none" : ""
                }`}
              >
                <Icon name="phone" /> 通話
              </button>
              <button
                onClick={() => (peerUser ? setShowChat(true) : addToast("尚未媒合技師，暫無法訊息", "error"))}
