  const { jobs, setJobs, users, logout, updateUser } = useApp();
  const [selectedJob, setSelectedJob] = useState(null);
  const [tab, setTab] = useState("market");
  const [showWallet, setShowWallet] = useState(false);
  const { addToast } = useToast();
  const [showProfile, setShowProfile] = useState(false);
  const [showInbox, setShowInbox] = useState(false);
  const [chatJob, setChatJob] = useState(null);
  const chatPeer = chatJob ? users.find((u) => u.id === chatJob.clientId) : null;
  const [nav, setNav] = useState("jobs");



  const marketJobs = jobs.filter((j) => j.status === "open");
  const myJobs = jobs.filter((j) => j.assignee === user.id);

  const list = tab === "market" ? marketJobs : myJobs;

  const pendingTail = jobs
    .filter((j) => j.assignee === user.id && j.status === "completed")
    .reduce((acc, j) => {
      const total = calcJobTotal(j);
      const dep = Number(j.depositAmount) || calcDeposit(total);
      const tail = Number(j.tailAmount) || (total - dep);
      return acc + tail;
    }, 0);

  const onWithdraw = (speed) => {
    const wallet = Number(user.wallet) || 0;
    if (wallet <= 0) {
      addToast("目前沒有可提領餘額", "error");
      return;
    }

    updateUser({ ...user, wallet: 0 });
    addToast(speed === "fast" ? "閃電提領已送出" : "標準提領已送出", "success");
    setShowWallet(false);
  };

  return (
    <div className="min-h-screen pb-32">
      {selectedJob && (
        <ProjectDetail
          job={selectedJob}
          user={user}
          onClose={() => setSelectedJob(null)}
          onUpdate={(u) => { setJobs((prev) => prev.map((j) => (j.id === u.id ? normalizeJob(u) : j))); setSelectedJob(normalizeJob(u)); }}
          addToast={addToast}
        />
      )}

      {showWallet && <WalletModal user={user} pendingTail={pendingTail} onWithdraw={onWithdraw} onClose={() => setShowWallet(false)} />}

      {showInbox && (
        <ConversationsModal
          me={user}
          onClose={() => { setShowInbox(false); setNav("jobs"); }}
          onOpen={(j) => { setChatJob(normalizeJob(j)); setShowInbox(false); }}
        />
      )}

      {chatJob && chatPeer && (
        <ChatModal
          job={chatJob}
          me={user}
          peer={chatPeer}
          onUpdate={(u) => {
            setJobs((prev) => prev.map((j) => (j.id === u.id ? normalizeJob(u) : j)));
            setChatJob(normalizeJob(u));
            setSelectedJob((prev) => (prev && prev.id === u.id ? normalizeJob(u) : prev));
          }}
          onClose={() => { setChatJob(null); setNav("jobs"); }}
        />
      )}

      {showProfile && <ProfileModal user={user} onClose={() => { setShowProfile(false); setNav("jobs"); }} />}
      <div className="p-6 sticky top-0 bg-white/80 backdrop-blur-md z-10 border-b border-slate-100 flex justify-between items-center">
        <div>
          <h2 className="text-xl font-bold text-slate-800">{tab === "market" ? "接案大廳" : "我的任務"}</h2>
          <p className="text-xs text-slate-400">待媒合 {marketJobs.length} | 我的 {myJobs.length}</p>
        </div>
        <div className="flex items-center gap-3">
          <button onClick={() => setShowProfile(true)} className="p-2 rounded-xl bg-slate-100 text-slate-600 hover:bg-slate-200" title="編輯資料"><Icon name="user-cog" size={16} /></button>
          <button onClick={() => setShowWallet(true)} className="px-3 py-2 rounded-xl bg-emerald-50 text-emerald-700 font-bold text-sm flex items-center gap-2 hover:bg-emerald-100">
            <Icon name="wallet" size={16} /> <span className="font-num">{formatCurrency(user.wallet)}</span>
          </button>
          <button onClick={logout}><Icon name="log-out" /></button>
        </div>
      </div>

      <div className="p-4">
        <div className="grid grid-cols-2 gap-3 mb-4">
          <button onClick={() => setTab("market")} className={`p-3 rounded-2xl font-bold text-sm border transition ${tab === "market" ? "bg-indigo-50 border-indigo-200 text-indigo-700" : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50"}`}>
            待媒合
          </button>
          <button onClick={() => setTab("mine")} className={`p-3 rounded-2xl font-bold text-sm border transition ${tab === "mine" ? "bg-indigo-50 border-indigo-200 text-indigo-700" : "bg-white border-slate-200 text-slate-600 hover:bg-slate-50"}`}>
            我的任務
          </button>
        </div>

        <div className="space-y-4">
          {list.map((j) => {
            const total = calcJobTotal(j);
            const pro = isProJob(j);
            const dist = pseudoDistanceKm(j.id);
            const statusColor = j.status === "open" ? "bg-green-100 text-green-700" : j.status === "active" ? "bg-blue-100 text-blue-700" : j.status === "completed" ? "bg-purple-100 text-purple-700" : "bg-slate-100 text-slate-600";

            return (
              <div key={j.id} onClick={() => setSelectedJob(j)} className="card-modern p-5 cursor-pointer">
                <div className="flex justify-between items-start mb-2">
                  <div className="flex items-center gap-2">
                    <span className={`text-xs px-2 py-1 rounded font-bold ${statusColor}`}>{j.status}</span>
                    {tab === "market" && pro && <span className="text-[10px] px-2 py-1 rounded-full bg-slate-900 text-white font-bold">PRO</span>}
                  </div>
                  <span className="font-bold text-lg text-indigo-600 font-num">{formatCurrency(total)}</span>
                </div>
                <h3 className="font-bold text-slate-800 mb-1">{j.title}</h3>
                <div className="flex justify-between items-center text-xs text-slate-500">
                  <span className="flex items-center gap-1"><Icon name="map-pin" size={12} /> {(j.address || "").substring(0, 10)}...</span>
                  {tab === "market" && <span className="font-num">約 {dist.toFixed(1)} km</span>}
                </div>
              </div>
            );
          })}

          {list.length === 0 && (
            <div className="text-sm text-slate-400 bg-white border border-slate-200 rounded-2xl p-6 text-center">
              {tab === "market" ? "目前沒有待媒合案件" : "你目前沒有進行中的任務"}
            </div>
          )}
        </div>
      </div>
      <BottomNav
        active={nav}
                onSelect={(id) => {
          if (id === "jobs") {
            setNav("jobs");
            setShowInbox(false);
            setChatJob(null);
            setShowProfile(false);
            return;
          }
          if (id === "messages") {
            setNav("messages");
            setShowProfile(false);
            setChatJob(null);
            setShowInbox(true);
            return;
          }
          if (id === "me") {
            setNav("me");
            setShowInbox(false);
            setChatJob(null);
            setShowProfile(true);
          }
        }}
        items={[
          { id: "jobs", label: "案件", icon: "file-text" },
          { id: "messages", label: "訊息", icon: "message-square" },
          { id: "me", label: "我的", icon: "user" },
        ]}
      />

</div>
  );
};

const AdminView = ({ user }) => {
  const { jobs, setJobs, users, setUsers, logout } = useApp();
  const [view, setView] = useState("overview");
  const [editModal, setEditModal] = useState(null);
  const [showReport, setShowReport] = useState(false);
  const DailyReport = ({ onClose }) => {
    const todayKey = new Date().toLocaleDateString();

    const createdToday = jobs.filter((j) => new Date(j.created_at).toLocaleDateString() === todayKey);
    const closedToday = jobs.filter((j) => j.paidAt && new Date(j.paidAt).toLocaleDateString() === todayKey);

    const depositCollected = createdToday.reduce((acc, j) => {
      if (!j.deposit_paid) return acc;
      const total = calcJobTotal(j);
      const dep = Number(j.depositAmount) || calcDeposit(total);
      return acc + dep;
    }, 0);

    const tailOutstanding = jobs
      .filter((j) => j.status !== "closed")
      .reduce((acc, j) => {
        const total = calcJobTotal(j);
        const dep = Number(j.depositAmount) || calcDeposit(total);
        const tail = Number(j.tailAmount) || (total - dep);
        return acc + tail;
      }, 0);

    const tailCollected = closedToday.reduce((acc, j) => {
      const total = calcJobTotal(j);
      const dep = Number(j.depositAmount) || calcDeposit(total);
      const tail = Number(j.tailAmount) || (total - dep);
      return acc + tail;
    }, 0);

    // Cashflow-style revenue: deposits collected today + tails collected today.
    const cashRevenue = depositCollected + tailCollected;

    return (
      <div className="fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
        <div className="bg-white w-full max-w-2xl rounded-xl overflow-hidden shadow-2xl">

          <div className="bg-indigo-600 p-6 text-white text-center">
            <h2 className="text-2xl font-bold">每日營運日報</h2>
            <p>{todayKey}</p>
          </div>

          <div className="p-8 grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
            <div className="p-4 bg-slate-50 rounded-xl">
              <p className="text-xs text-slate-400">今日新增</p>
              <h3 className="text-2xl font-bold">{createdToday.length}</h3>
            </div>
            <div className="p-4 bg-slate-50 rounded-xl">
              <p className="text-xs text-slate-400">今日完工</p>
              <h3 className="text-2xl font-bold">{closedToday.length}</h3>
            </div>
            <div className="p-4 bg-slate-50 rounded-xl">
              <p className="text-xs text-slate-400">已收訂金 (30%)</p>
              <h3 className="text-xl font-bold text-indigo-600 font-num">{formatCurrency(depositCollected)}</h3>
            </div>
            <div className="p-4 bg-slate-50 rounded-xl">
              <p className="text-xs text-slate-400">待收尾款 (未結案)</p>
              <h3 className="text-xl font-bold text-rose-600 font-num">{formatCurrency(tailOutstanding)}</h3>
            </div>
          </div>

          <div className="px-8 pb-8">
            <div className="card-modern p-6">
              <div className="flex items-center justify-between">
                <div>
                  <div className="text-xs font-bold text-slate-400 uppercase">今日現金流營收</div>
                  <div className="text-xs text-slate-400 mt-1">訂金 + 今日驗收尾款</div>
                </div>
                <div className="text-2xl font-bold text-emerald-600 font-num">{formatCurrency(cashRevenue)}</div>
              </div>
            </div>
          </div>

          <div className="p-6 border-t"><button onClick={onClose} className="w-full btn btn-primary">關閉</button></div>
        </div>
      </div>
    );
  };

  const EditModal = ({ data, type, onClose }) => {
    const [form, setForm] = useState({ ...data });

    const handleSave = () => {
      if (type === "job") setJobs((prev) => prev.map((j) => (j.id === data.id ? normalizeJob(form) : j)));
      else setUsers((prev) => prev.map((u) => (u.id === data.id ? form : u)));
      alert("資料已更新");
      onClose();
    };

    return (
      <div className="fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
        <div className="bg-white w-full max-w-md rounded-xl p-6 shadow-2xl">

          <h3 className="font-bold text-lg mb-4">編輯 {type === "job" ? "工單" : "會員"}</h3>
          <div className="space-y-3 mb-6">
            {Object.keys(form).map((k) =>
              (typeof form[k] === "string" || typeof form[k] === "number") &&
              k !== "id" && (
                <div key={k}>
                  <label className="text-xs text-slate-400 uppercase">{k}</label>
                  <input className="input-modern py-2" value={form[k]} onChange={(e) => setForm({ ...form, [k]: e.target.value })} />
                </div>
              )
            )}
          </div>
          <div className="flex gap-3">
            <button onClick={onClose} className="flex-1 btn btn-outline px-4 py-2 rounded">取消</button>
            <button onClick={handleSave} className="flex-1 btn btn-primary px-4 py-2 rounded">保存</button>
          </div>
        </div>
      </div>
    );
  };

  const revenue = jobs
    .filter((j) => j.status === "closed")
    .reduce((acc, j) => acc + (Number(j.releasedTotal) || calcJobTotal(j)), 0);

  const stats = { revenue, jobs: jobs.length, users: users.length };

  return (
    <div className="min-h-screen bg-slate-100 flex flex-col md:flex-row">
      {showReport && <DailyReport onClose={() => setShowReport(false)} />}
      {editModal && <EditModal data={editModal.data} type={editModal.type} onClose={() => setEditModal(null)} />}

      <aside className="w-full md:w-64 bg-white border-r p-6 flex flex-col">
        <div className="flex items-center gap-3 font-bold text-xl text-indigo-700 mb-10"><Icon name="cloud-lightning" /> 雲程中控</div>
        <nav className="space-y-1 flex-1">
          {[{ id: "overview", label: "戰情儀表", icon: "layout-dashboard" }, { id: "jobs", label: "全域工單", icon: "file-text" }, { id: "users", label: "會員管理", icon: "users" }].map((i) => (
            <button key={i.id} onClick={() => setView(i.id)} className={`w-full text-left p-3 rounded-xl font-bold flex items-center gap-3 transition-all ${view === i.id ? "bg-indigo-50 text-indigo-600" : "text-slate-500 hover:bg-slate-50"}`}>
              <Icon name={i.icon} size={18} /> {i.label}
            </button>
          ))}
        </nav>
        <button onClick={() => setShowReport(true)} className="mb-4 w-full py-3 bg-slate-800 text-white rounded-xl text-sm font-bold shadow-lg flex items-center justify-center gap-2"><Icon name="file-text" size={16} /> 生成日報</button>
        <button onClick={logout} className="text-slate-400 hover:text-red-500 flex items-center gap-2 px-3"><Icon name="log-out" size={16} /> 登出系統</button>
      </aside>

      <main className="flex-1 p-8 overflow-y-auto">
        <h2 className="text-2xl font-bold text-slate-800 mb-6">{view.toUpperCase()}</h2>

        {view === "overview" && (
          <>
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
              <div className="card-modern p-6"><p className="text-sm text-slate-400">總營收</p><h3 className="text-3xl font-bold text-emerald-500 font-num">${stats.revenue.toLocaleString()}</h3></div>
              <div className="card-modern p-6"><p className="text-sm text-slate-400">案件數</p><h3 className="text-3xl font-bold text-indigo-600 font-num">{stats.jobs}</h3></div>
              <div className="card-modern p-6"><p className="text-sm text-slate-400">會員數</p><h3 className="text-3xl font-bold text-slate-700 font-num">{stats.users}</h3></div>
            </div>
            <div className="card-modern p-6 mt-6"><h3 className="font-bold text-slate-800 mb-4">營收趨勢</h3><SimpleBarChart data={[30, 50, 45, 80, 60, 90, 100]} /></div>
          </>
        )}

        {view === "jobs" && (
          <div className="card-modern overflow-hidden">
            <table className="w-full text-left text-sm">
              <thead className="bg-slate-50 text-slate-500 border-b"><tr><th className="p-4">ID</th><th className="p-4">標題</th><th className="p-4">狀態</th><th className="p-4">操作</th></tr></thead>
              <tbody>
                {jobs.map((j) => (
                  <tr key={j.id} className="border-b hover:bg-slate-50">
                    <td className="p-4 font-mono text-slate-400">{String(j.id).slice(-6)}</td>
                    <td className="p-4 font-bold">{j.title}</td>
                    <td className="p-4"><StatusBadge status={j.status} /></td>
                    <td className="p-4"><button onClick={() => setEditModal({ type: "job", data: j })} className="text-indigo-600 font-bold hover:underline">管理</button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}

        {view === "users" && (
          <div className="card-modern overflow-hidden">
            <table className="w-full text-left text-sm">
              <thead className="bg-slate-50 text-slate-500 border-b"><tr><th className="p-4">姓名</th><th className="p-4">角色</th><th className="p-4">狀態</th><th className="p-4">操作</th></tr></thead>
              <tbody>
                {users.map((u) => (
                  <tr key={u.id} className="border-b hover:bg-slate-50">
                    <td className="p-4 font-bold">{u.name}</td>
                    <td className="p-4"><span className="bg-slate-100 px-2 py-0.5 rounded text-xs">{u.role}</span></td>
                    <td className="p-4 text-green-600">{u.status}</td>
                    <td className="p-4"><button onClick={() => setEditModal({ type: "user", data: u })} className="text-indigo-600 font-bold hover:underline">編輯</button></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </main>
    </div>
  );
};

// --- App ---
const App = () => {
  const { user } = useApp();
  const [showHelp, setShowHelp] = useState(false);
  const [showDiag, setShowDiag] = useState(false);

  return (
    <>
      {!user ? (
        <AuthScreen />
      ) : user.role === "admin" ? (
        <AdminView user={user} />
      ) : user.role.startsWith("client") ? (
        <ClientView user={user} />
      ) : (
        <TechView user={user} />
      )}

      {showHelp && <HelpModal onClose={() => setShowHelp(false)} onDiagnostics={() => { setShowHelp(false); setShowDiag(true); }} />}

      {showDiag && <DiagnosticsModal onClose={() => setShowDiag(false)} />}

      <button
        onClick={() => setShowHelp(true)}
        className="fixed bottom-24 right-6 z-[40] w-14 h-14 rounded-2xl bg-white border border-slate-200 shadow-xl flex items-center justify-center text-indigo-600 hover:bg-slate-50 active:scale-95 transition"
        aria-label="操作說明"
        title="操作說明"
      >
        <Icon name="help-circle" size={22} />
      </button>
    </>
  );
};

const root = ReactDOM.createRoot(document.getElementById("root"));
root.render(
  <ErrorBoundary>
    <AppProvider>
      <ToastProvider>
        <App />
      </ToastProvider>
    </AppProvider>
  </ErrorBoundary>
);




</script>
  </body>
</html>





















