const ProfileModal = ({ user, onClose }) => {
  const { updateUser } = useApp();
  const { addToast } = useToast();

  const [form, setForm] = useState({
    name: user?.name || "",
    phone: user?.phone || "",
    address: user?.address || "",
  });

  const roleLabel = user?.role === "engineer" ? "技師" : user?.role?.startsWith("client") ? "客戶" : (user?.role || "");

  const save = () => {
    const name = String(form.name || "").trim();
    const phone = String(form.phone || "").trim();
    const address = String(form.address || "").trim();

    if (!name) {
      addToast("姓名不可為空", "error");
      return;
    }

    const digits = phone.replace(/[^0-9+]/g, "");
    if (phone && digits.length < 6) {
      addToast("電話格式不正確", "error");
      return;
    }

    updateUser({
      ...user,
      name,
      phone,
      address,
      avatar: name ? name[0] : (user.avatar || "U"),
    });

    addToast("個人資料已更新", "success");
    onClose();
  };

  return (
    <div className="fixed inset-0 z-[190] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-lg md:rounded-3xl rounded-t-3xl shadow-2xl overflow-hidden">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center">
              <Icon name="user-cog" size={22} />
            </div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">編輯個人資料</h3>
              <p className="text-xs text-slate-400">{roleLabel} · {user?.email || ""}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 space-y-4">
          <div>
            <label className="text-xs font-bold text-slate-500 mb-2 block">姓名</label>
            <input className="input-modern" value={form.name} onChange={(e) => setForm((p) => ({ ...p, name: e.target.value }))} placeholder="姓名" />
          </div>
          <div>
            <label className="text-xs font-bold text-slate-500 mb-2 block">電話</label>
            <input className="input-modern" value={form.phone} onChange={(e) => setForm((p) => ({ ...p, phone: e.target.value }))} placeholder="電話" />
          </div>
          <div>
            <label className="text-xs font-bold text-slate-500 mb-2 block">地址</label>
            <input className="input-modern" value={form.address} onChange={(e) => setForm((p) => ({ ...p, address: e.target.value }))} placeholder="地址" />
          </div>
        </div>

        <div className="p-6 border-t border-slate-100 bg-white">
          <div className="grid grid-cols-2 gap-3">
            <button onClick={onClose} className="w-full btn btn-outline">取消</button>
            <button onClick={save} className="w-full btn btn-primary">儲存</button>
          </div>
        </div>
      </div>
    </div>
  );
};

