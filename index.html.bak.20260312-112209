const ClientCreateJob = ({ onClose }) => {
  const { user, addJob, updateUser } = useApp();
  const [form, setForm] = useState({
    title: "",
    type: "",
    address: user?.address || "",
    desc: "",
    labor: "",
    material: "",
    date: "",
    items: {},
  });
  const [isAiLoading, setIsAiLoading] = useState(false);

  const currentSubItems = useMemo(() => {
    const category = PROJECT_CATEGORIES.find((c) => c.label === form.type);
    return category ? category.subItems : [];
  }, [form.type]);

  useEffect(() => {
    if (!currentSubItems || currentSubItems.length === 0) return;

    let laborTotal = 0;
    let materialTotal = 0;
    let descText = "";

    Object.entries(form.items).forEach(([id, qty]) => {
      if (qty > 0) {
        const item = currentSubItems.find((i) => i.id === id);
        if (item) {
          materialTotal += item.price * qty;
          laborTotal += item.labor * qty;
          descText += `${item.name} x${qty}, `;
        }
      }
    });

    if (laborTotal > 0 || materialTotal > 0) {
      setForm((prev) => ({ ...prev, labor: laborTotal, material: materialTotal, desc: descText.slice(0, -2) }));
    }
  }, [form.items, currentSubItems]);

  const handleItemChange = (id, delta) => {
    setForm((prev) => {
      const currentQty = prev.items[id] || 0;
      const newQty = Math.max(0, currentQty + delta);
      return { ...prev, items: { ...prev.items, [id]: newQty } };
    });
  };
  const handleSubmit = () => {
    if (!form.title || !form.type || !form.address) {
      addToast("請填寫完整資訊", "error");
      return;
    }

    const labor = Number.parseInt(form.labor, 10) || 0;
    const material = Number.parseInt(form.material, 10) || 0;
    const total = labor + material;

    if (total <= 0) {
      addToast("請設定預算金額", "error");
      return;
    }

    const deposit = calcDeposit(total);
    const tail = total - deposit;

    const wallet = Number(user.wallet) || 0;
    if (wallet < deposit) {
      addToast(`錢包餘額不足，訂金需要 ${formatCurrency(deposit)}`, "error");
      return;
    }

    updateUser({ ...user, wallet: wallet - deposit });

    addJob({
      id: `J-${Date.now()}`,
      title: form.title,
      type: form.type,
      address: form.address,
      desc: form.desc,
      scheduledDate: form.date,
      status: "open",
      clientId: user.id,
      clientName: user.name,
      laborBudget: labor,
      materialBudget: material,
      deposit_paid: true,
      depositAmount: deposit,
      tailAmount: tail,
      created_at: new Date().toISOString(),
      materials: [],
      photos: [],
      signature: null,
    });

    addToast(`訂金已支付 ${formatCurrency(deposit)}，已成功發案`, "success");
    onClose();
  };

  const handleAi = () => {
    setIsAiLoading(true);
    setTimeout(() => {
      setForm((p) => ({ ...p, labor: 3000, material: 2000 }));
      setIsAiLoading(false);
    }, 800);
  };

  const total = (Number.parseInt(form.labor, 10) || 0) + (Number.parseInt(form.material, 10) || 0);

  return (
    <div className="fixed inset-0 z-50 bg-slate-900/40 backdrop-blur-md flex items-center justify-center p-4 animate-enter">
      <div className="bg-white w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl flex flex-col max-h-[90vh]">

        <div className="p-6 border-b border-slate-50 flex justify-between items-center">
          <h3 className="font-bold text-xl text-slate-800">發布需求</h3>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 space-y-4 overflow-y-auto flex-1">
          <div>
            <label className="text-xs font-bold text-slate-500 mb-2 block">工程類別</label>
            <div className="grid grid-cols-3 gap-2 mb-4">
              {PROJECT_CATEGORIES.map((cat) => (
                <button key={cat.id} onClick={() => setForm({ ...form, type: cat.label, items: {} })} className={`category-btn ${form.type === cat.label ? "active" : "inactive"}`}>
                  <Icon name={cat.icon} size={24} className="mb-1" /> <span className="text-[10px] font-bold">{cat.label}</span>
                </button>
              ))}
            </div>

            {currentSubItems.length > 0 && (
              <div className="bg-slate-50 p-4 rounded-xl border border-slate-200 animate-slide-down">
                <label className="text-xs font-bold text-slate-500 mb-2 block">選擇細項 (自動計算)</label>
                <div className="space-y-2">
                  {currentSubItems.map((item) => (
                    <div key={item.id} className="flex justify-between items-center bg-white p-2 rounded-lg border border-slate-100">
                      <div>
                        <div className="text-sm font-bold text-slate-700">{item.name}</div>
                        <div className="text-xs text-slate-400">${item.price + item.labor} / {item.unit}</div>
                      </div>
                      <div className="flex items-center gap-3">
                        <button onClick={() => handleItemChange(item.id, -1)} className="w-6 h-6 rounded-full bg-slate-100">-</button>
                        <span className="w-4 text-center font-bold text-sm">{form.items[item.id] || 0}</span>
                        <button onClick={() => handleItemChange(item.id, 1)} className="w-6 h-6 rounded-full bg-indigo-100 text-indigo-600">+</button>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )}
          </div>

          <div className="space-y-3 pt-2 border-t border-slate-100">
            <input className="input-modern" placeholder="案件標題" value={form.title} onChange={(e) => setForm({ ...form, title: e.target.value })} />
            <input className="input-modern" placeholder="施工地址" value={form.address} onChange={(e) => setForm({ ...form, address: e.target.value })} />
            <div className="flex gap-3"><input type="datetime-local" className="input-modern" value={form.date} onChange={(e) => setForm({ ...form, date: e.target.value })} /></div>
            <textarea className="input-modern h-24 resize-none" placeholder="描述..." value={form.desc} onChange={(e) => setForm({ ...form, desc: e.target.value })} />
          </div>

          <div className="bg-indigo-50 p-5 rounded-3xl">
            <div className="flex justify-between items-center mb-4">
              <h4 className="font-bold text-indigo-900">預算設定</h4>
              {(!currentSubItems || currentSubItems.length === 0) && (
                <button onClick={handleAi} className="text-xs bg-white text-indigo-600 px-3 py-1.5 rounded-full font-bold shadow-sm flex items-center gap-1">
                  {isAiLoading ? <Icon name="loader-2" className="animate-spin" size={12} /> : <Icon name="sparkles" size={12} />} AI 估價
                </button>
              )}
            </div>
            <div className="grid grid-cols-2 gap-4">
              <input type="number" className="w-full p-2 rounded-lg text-right font-mono font-num" placeholder="工資" value={form.labor} onChange={(e) => setForm({ ...form, labor: e.target.value })} />
              <input type="number" className="w-full p-2 rounded-lg text-right font-mono font-num" placeholder="材料" value={form.material} onChange={(e) => setForm({ ...form, material: e.target.value })} />
            </div>
            <div className="mt-3 text-right text-indigo-900 font-bold text-lg font-num">總計: ${total.toLocaleString()}</div>
          </div>
        </div>

        <div className="p-6 border-t border-slate-50">
          <button onClick={handleSubmit} className="w-full btn btn-primary shadow-xl shadow-indigo-200">支付訂金 (30%) 並發布</button>
        </div>
      </div>
    </div>
  );
};


const CallModal = ({ name, phone, onClose, addToast }) => {
  const clean = String(phone || "");
  const tel = `tel:${clean.replace(/[^0-9+]/g, "")}`;

  const copy = async () => {
    try {
      await navigator.clipboard.writeText(clean);
      addToast("已複製電話", "success");
    } catch {
      // Fallback for non-secure contexts (file://)
      window.prompt("複製電話", clean);
    }
  };

  const dial = () => {
    if (!clean) {
      addToast("對方未提供電話", "error");
      return;
    }
    window.location.href = tel;
  };

  return (
    <div className="fixed inset-0 z-[170] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-md md:rounded-3xl rounded-t-3xl shadow-2xl overflow-hidden">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-indigo-50 text-indigo-600 flex items-center justify-center"><Icon name="phone" size={20} /></div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">通話</h3>
              <p className="text-xs text-slate-400">{name || "對方"}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div className="p-6 space-y-4">
          <div className="card-modern p-5">
            <div className="text-xs font-bold text-slate-400 uppercase mb-2">電話</div>
            <div className="text-2xl font-bold text-slate-900 font-num">{clean || "未提供"}</div>
          </div>

          <div className="grid grid-cols-2 gap-3">
            <button onClick={copy} className="btn btn-outline py-3 rounded-xl">複製</button>
            <button onClick={dial} className="btn btn-primary py-3 rounded-xl">撥打</button>
          </div>
        </div>
      </div>
    </div>
  );
};

const ChatModal = ({ job, me, peer, onUpdate, onClose }) => {
  const [draft, setDraft] = useState("");
  const listRef = React.useRef(null);

  const messages = Array.isArray(job.messages) ? job.messages : [];

  useEffect(() => {
    const el = listRef.current;
    if (!el) return;
    el.scrollTop = el.scrollHeight;
  }, [messages.length]);

  const send = () => {
    const text = draft.trim();
    if (!text) return;

    const msg = {
      id: `M-${Date.now()}`,
      fromId: me.id,
      fromName: me.name,
      text,
      ts: new Date().toISOString(),
    };

    onUpdate({ ...job, messages: [...messages, msg] });
    setDraft("");
  };

  return (
    <div className="fixed inset-0 z-[175] bg-slate-900/60 backdrop-blur-md flex items-end md:items-center justify-center p-0 md:p-6 animate-enter">
      <div className="bg-white w-full max-w-2xl md:rounded-3xl rounded-t-3xl h-[85vh] md:h-[75vh] shadow-2xl overflow-hidden flex flex-col">
        <div className="p-6 border-b border-slate-100 flex items-center justify-between">
          <div className="flex items-center gap-3">
            <div className="w-10 h-10 rounded-2xl bg-slate-100 text-slate-700 flex items-center justify-center"><Icon name="message-square" size={20} /></div>
            <div>
              <h3 className="font-bold text-lg text-slate-900">訊息</h3>
              <p className="text-xs text-slate-400">{peer?.name || "對方"} · {job.title}</p>
            </div>
          </div>
          <button onClick={onClose} className="p-2 bg-slate-50 rounded-full hover:bg-slate-100"><Icon name="x" /></button>
        </div>

        <div ref={listRef} className="flex-1 overflow-y-auto p-6 space-y-3 bg-slate-50">
          {messages.length === 0 && <div className="text-sm text-slate-400 text-center">尚無訊息，輸入內容開始對話。</div>}
          {messages.map((m) => {
            const mine = m.fromId === me.id;
            return (
              <div key={m.id} className={`flex ${mine ? "justify-end" : "justify-start"}`}>
                <div className={`max-w-[80%] p-3 rounded-2xl text-sm shadow-sm ${mine ? "bg-indigo-600 text-white" : "bg-white text-slate-700"}`}>
                  <div className={`text-[10px] mb-1 ${mine ? "text-indigo-100" : "text-slate-400"}`}>{mine ? "我" : (m.fromName || "對方")}</div>
                  <div className="whitespace-pre-wrap leading-relaxed">{m.text}</div>
                </div>
              </div>
            );
          })}
        </div>

        <div className="p-4 border-t bg-white">
          <div className="flex gap-2">
            <input className="input-modern flex-1" placeholder="輸入訊息..." value={draft} onChange={(e) => setDraft(e.target.value)} onKeyDown={(e) => { if (e.key === "Enter") send(); }} />
            <button onClick={send} className="btn btn-primary px-5">送出</button>
          </div>
        </div>
      </div>
    </div>
  );
};

const ConversationsModal = ({ me, onClose, onOpen }) => {
